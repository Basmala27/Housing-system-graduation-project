// Utility functions for data consistency
export const getApplicationsFromStorage = () => {
    try {
        const saved = localStorage.getItem('housingApplications');
        if (saved) {
            const parsed = JSON.parse(saved);
            return parsed.length > 0 ? parsed : SHARED_FALLBACK_APPLICATIONS;
        }
    } catch (err) {
        console.error('Failed to load applications from localStorage:', err);
    }
    return SHARED_FALLBACK_APPLICATIONS;
};

export const getApplicationStats = (applications) => {
    const stats = {
        total: applications.length,
        pending: applications.filter(app => app.status === 'pending').length,
        approved: applications.filter(app => app.status === 'approved').length,
        rejected: applications.filter(app => app.status === 'rejected').length
    };
    return stats;
};

export const getProjectStats = (applications, projects) => {
    const projectStats = projects.map(project => {
        const projectApplications = applications.filter(app => app.projectName === project.name);
        return {
            projectName: project.name,
            totalApplications: projectApplications.length,
            approved: projectApplications.filter(app => app.status === 'approved').length,
            rejected: projectApplications.filter(app => app.status === 'rejected').length,
            pending: projectApplications.filter(app => app.status === 'pending').length
        };
    });
    return projectStats;
};
